import aiml

def play():
    ker = aiml.Kernel()
    ker.learn("pract4.aiml")

    print("Game bot: Type Rock Paper Scissor to play. Type quit to exit")

    while True:
        user_input = input("You: ").strip().upper()

        if user_input == "QUIT":
            print("Good Day")
            break

        elif user_input in ["ROCK", "PAPER", "SCISSOR"]:
            response = ker.respond(user_input)
            print("Game Bot:", response)

        else:
            print("I dont know what you are talking about...... Type Rock Paper or Scissor to continue")

play()
